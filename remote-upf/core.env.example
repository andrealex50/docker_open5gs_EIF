# Apply these values to the exigence1 environment only when switching from the
# local UPF to the remote UPF.
SMF_UPF_IP=10.255.35.34
UPF_METRICS_IP=10.255.35.34

# Measure the host that runs the isolated UPF. Calibrate this baseline again
# after the UPF is deployed and before collecting final results.
SCAPHANDRE_PROMQL_TEMPLATE=increase(scaph_host_energy_microjoules{job="scaphandre-exigence2"}[{window}])/1000000
ENERGY_HOST_IDLE_BASELINE_W=4.7
