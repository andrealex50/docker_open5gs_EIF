OPEN5GS_IMAGE=docker_open5gs

# Exigence2 host addresses used by PFCP, GTP-U and metrics.
UPF_IP=10.255.35.34
UPF_ADVERTISE_IP=10.255.35.34

# The SMF remains in the exigence1 Docker network. Exigence2 needs the route
# installed by configure-routing.sh before starting the UPF.
UPF_SMF_IP=172.22.0.7

UPF_TUNTAP_MODE=tun
UPF_INTERNET_APN_IF_NAME=ogstun
UPF_IMS_APN_IF_NAME=ogstun2
UE_IPV4_INTERNET=192.168.100.0/24
UE_IPV4_IMS=192.168.101.0/24
PCSCF_IP=172.22.0.21
MAX_NUM_UE=1024
